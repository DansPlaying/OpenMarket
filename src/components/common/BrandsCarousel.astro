---
const { brandsData } = Astro.props;

const brands = brandsData.concat(brandsData);
const slideWidth = 200;
const trackWidth = slideWidth * brands.length;
---

<style define:vars={{ trackWidth: `${trackWidth}px` }}>
  .brands-slider {
    overflow: hidden;
    width: 100%;
    background-color: white;
    padding: 0.625rem 0;
  }

  .brands-slider .slide-track {
    display: flex;
    align-items: center;
    width: var(--trackWidth);
    animation: brands-scroll 30s linear infinite;
  }

  .brands-slider .slide {
    width: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.5rem;
    flex-shrink: 0;
  }

  .brands-slider .slide img {
    max-height: 48px;
    width: auto;
    object-fit: contain;
  }

  @keyframes brands-scroll {
    from {
      transform: translateX(0);
    }
    to {
      /* -50% of the track width = exactly the original brands' total width.
         Since the track is [originals][duplicates], this lands at the start
         of the duplicates — visually identical to the start — making the
         loop perfectly seamless for any number of brands. */
      transform: translateX(-50%);
    }
  }
</style>

<div class='brands-slider'>
  <div class='slide-track'>
    {
      brands.map((brand: string, index: number) => (
        <div class='slide'>
          <img src={brand} alt={`Brand ${index + 1}`} loading='lazy' />
        </div>
      ))
    }
  </div>
</div>
