---
import Layout from '~/layouts/PageLayout.astro';
// import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import Carousel from '~/components/common/Carousel.astro';
// import Headline from '~/components/ui/Headline.astro';
import BrandsCarousel from '~/components/common/BrandsCarousel.astro';
import Hero from '~/components/widgets/Hero.astro';
import { glassesBrands, suppliesBrands } from '../core/data/images-list'; // Importa la lista de imágenes

const metadata = {
  title: 'AstroWind — Free template for creating websites with Astro + Tailwind CSS',
  ignoreTitleTemplate: true,
};

---

<Layout metadata={metadata}>
  <Carousel />

  <Hero image={{ src: 'https://rgoptics-imagenes.s3.us-west-1.wasabisys.com/open-market/aparatos-oftalmicos.png', alt: 'aparatos-oftalmicos' }}>
    <Fragment slot='title'>OpticaMarket is all you need</Fragment>

    <Fragment slot='subtitle'>
      <span class='hidden sm:inline'>
        <span class='font-semibold'>We are a </span>wholesaler of many of the products in the ophthalmic sector.</span>
    </Fragment>
  </Hero>

  <Content
    isReversed
    hasBeforeContent
    tagline="Brand's variety"
    title='We have a huge catalog of sunglasses and frames.'
    items={[
      {
        title: 'Wide Variety of Styles',
        description:
          'We offer an extensive collection of sunglasses and frames for all tastes, from classic to the most modern designs. Find all you need!',
      },
      {
        title: 'Guaranteed Quality and Durability',
        description:
          'All pair of glasses is made with high-quality materials, ensuring not only style but also strength and comfort with every wear.',
      },
      {
        title: 'Protection and Fashion in One Place',
        description: 'We have glasses that combine UV protection and attractive design.',
      },
    ]}
    image={{
      src: 'https://rgoptics-imagenes.s3.us-west-1.wasabisys.com/open-market/lentes-variados.png',
      alt: 'Colorful Image',
    }}
  >
    <Fragment slot='content'>
      <h3 class='text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2'>
        Complete or modernize your catalog
      </h3>
      Here you will find everything you need
    </Fragment>

    <Fragment slot='bg'>
      <div class='absolute inset-0 bg-blue-50 dark:bg-transparent'></div>
    </Fragment>
  </Content>

  <div class='h-[5px] bg-blue-50 dark:bg-transparent'></div>

  <div class='bg-blue-50 dark:bg-transparent'>
    <div class='max-w-6xl mx-auto'>
      <BrandsCarousel brandsData={glassesBrands} />
    </div>
  </div>

  <div class='h-[64px] bg-blue-50 dark:bg-transparent'></div>
  
  <Content
    isAfterContent
    tagline="Different supplies"
    title='Whatever you need for selling to optics or laboratories'
    items={[
      {
        title: 'Wholesale for Optical and Laboratory Supplies',
        description: `We offer an endless variety of products for optics and laboratories at wholesale prices. Find everything you need in one place!`,
      },
      {
        title: 'We are your ideal partner',
        description:
          'For sourcing materials for optics and laboratories. Buy in bulk and save!',
      },
      {
        title: 'Looking for quality and variety?',
        description:
          "We have all the supplies your business needs, from optics to laboratories, with the best wholesale rates in the market.",
      },
    ]}
    image={{
      src: 'https://rgoptics-imagenes.s3.us-west-1.wasabisys.com/open-market/insumos.png',
      alt: 'insumos Image',
    }}
  >
    <Fragment slot='bg'>
      <div class='absolute inset-0 bg-blue-50 dark:bg-transparent'></div>
    </Fragment>
  </Content>

  <div class='h-[5px] bg-blue-50 dark:bg-transparent'></div>

  <div class='bg-blue-50 dark:bg-transparent'>
    <div class='max-w-6xl mx-auto'>
      <BrandsCarousel brandsData={suppliesBrands} />
    </div>
  </div>

  <div class='h-[64px] bg-blue-50 dark:bg-transparent'></div>

